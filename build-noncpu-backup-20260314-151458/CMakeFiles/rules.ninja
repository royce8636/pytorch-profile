#############################################
# Rule for linking CXX shared library.

rule CXX_SHARED_LIBRARY_LINKER__torch_python_Release
  command = $PRE_LINK && /usr/bin/c++ -fPIC $LANGUAGE_COMPILE_FLAGS $ARCH_FLAGS $LINK_FLAGS -shared $SONAME_FLAG$SONAME -o $TARGET_FILE $in $LINK_PATH $LINK_LIBRARIES && /home/royce/.local/lib/python3.10/site-packages/cmake/data/bin/cmake -E __run_co_compile --lwyu="ldd;-u;-r" --source=lib/libtorch_python.so && $POST_BUILD
  description = Linking CXX shared library $TARGET_FILE
  restat = $RESTAT


