#############################################
# Rule for re-running cmake.

rule RERUN_CMAKE
  command = /home/royce/.local/lib/python3.10/site-packages/cmake/data/bin/cmake --regenerate-during-build -S/data/pytorch-source -B/data/pytorch-source/build
  description = Re-running CMake...
  generator = 1


#############################################
# Rule for cleaning all built files.

rule CLEAN
  command = /tmp/ptvenv/bin/ninja $FILE_ARG -t clean $TARGETS
  description = Cleaning all built files...


#############################################
# Rule for printing all primary targets available.

rule HELP
  command = /tmp/ptvenv/bin/ninja -t targets
  description = All primary targets available:

