#############################################
# Rule for linking C executable.

rule C_EXECUTABLE_LINKER__addSuffix_Release
  command = $PRE_LINK && /usr/bin/cc $FLAGS $LINK_FLAGS $in -o $TARGET_FILE $LINK_PATH $LINK_LIBRARIES && /home/royce/.local/lib/python3.10/site-packages/cmake/data/bin/cmake -E __run_co_compile --lwyu="ldd;-u;-r" --source=sleef/bin/addSuffix && $POST_BUILD
  description = Linking C executable $TARGET_FILE
  restat = $RESTAT


